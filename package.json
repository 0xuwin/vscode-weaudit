{
    "name": "weaudit",
    "displayName": "weAudit",
    "description": "Bookmark findings and quickly navigate to areas of interest in the codebase",
    "version": "1.3.1",
    "publisher": "trailofbits",
    "author": "Trail of Bits",
    "categories": [],
    "repository": {
        "type": "git",
        "url": "https://github.com/trailofbits/vscode-weaudit"
    },
    "keywords": [
        "security",
        "audit",
        "code-review"
    ],
    "license": "SEE LICENSE IN LICENSE",
    "galleryBanner": {
        "color": "#ffebdb",
        "theme": "light"
    },
    "icon": "media/icon.png",
    "engines": {
        "vscode": "^1.108.0"
    },
    "activationEvents": [
        "onStartupFinished",
        "onView:weAudit"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "weAudit",
                    "title": "weAudit",
                    "icon": "media/weAuditLogo.svg"
                }
            ]
        },
        "views": {
            "weAudit": [
                {
                    "id": "codeMarker",
                    "name": "List of Findings",
                    "contextualTitle": "weAudit: "
                },
                {
                    "type": "webview",
                    "id": "findingDetails",
                    "name": "Finding Details",
                    "contextualTitle": "weAudit"
                },
                {
                    "id": "resolvedFindings",
                    "name": "Resolved Findings",
                    "contextualTitle": "weAudit"
                },
                {
                    "id": "savedFindings",
                    "name": "weAudit Files",
                    "contextualTitle": "weAudit"
                }
            ]
        },
        "commands": [
            {
                "command": "weAudit.copyFindingAsMarkdown",
                "title": "Copy as Markdown",
                "icon": "$(markdown)"
            },
            {
                "command": "weAudit.copyFindingAsMarkdownFromDetails",
                "title": "Copy as Markdown",
                "icon": "$(markdown)"
            },
            {
                "command": "weAudit.copyEntryPermalink",
                "title": "Copy Audit Permalink",
                "icon": "$(link)"
            },
            {
                "command": "weAudit.copyEntryPermalinks",
                "title": "Copy All Audit Permalinks",
                "icon": "$(link)"
            },
            {
                "command": "weAudit.copySelectedCodePermalink",
                "title": "weAudit: Copy Permalink (Audit Repository)"
            },
            {
                "command": "weAudit.copySelectedCodeClientPermalink",
                "title": "weAudit: Copy Permalink (Client Repository)"
            },
            {
                "command": "weAudit.resolveFinding",
                "title": "Resolve Finding",
                "icon": "$(pass)"
            },
            {
                "command": "weAudit.editLocationEntry",
                "title": "Edit Location Label",
                "icon": "$(edit)"
            },
            {
                "command": "weAudit.findAndLoadConfigurationFiles",
                "title": "Update Files",
                "icon": "$(refresh)"
            },
            {
                "command": "weAudit.restoreFinding",
                "title": "Restore Finding",
                "icon": "$(check)"
            },
            {
                "command": "weAudit.deleteFinding",
                "title": "Delete Finding",
                "icon": "$(trash)"
            },
            {
                "command": "weAudit.deleteLocation",
                "title": "Delete Location",
                "icon": "$(trash)"
            },
            {
                "command": "weAudit.deleteResolvedFinding",
                "title": "Delete Finding",
                "icon": "$(trash)"
            },
            {
                "command": "weAudit.deleteAllResolvedFinding",
                "title": "Delete All Findings",
                "icon": "$(clear-all)"
            },
            {
                "command": "weAudit.restoreAllResolvedFindings",
                "title": "Restore All Findings",
                "icon": "$(check-all)"
            },
            {
                "command": "weAudit.toggleTreeViewMode",
                "title": "Toggle View Mode",
                "icon": "$(sort-precedence)"
            },
            {
                "command": "weAudit.toggleAudited",
                "title": "weAudit: Mark File as Reviewed"
            },
            {
                "command": "weAudit.addPartiallyAudited",
                "title": "weAudit: Mark Region as Reviewed"
            },
            {
                "command": "weAudit.addFinding",
                "title": "weAudit: New Finding from Selection"
            },
            {
                "command": "weAudit.addNote",
                "title": "weAudit: New Note from Selection"
            },
            {
                "command": "weAudit.deleteLocationUnderCursor",
                "title": "weAudit: Delete Location Under Cursor"
            },
            {
                "command": "weAudit.showMarkedFilesDayLog",
                "title": "weAudit: Show Daily Log",
                "icon": "$(output)"
            },
            {
                "command": "weAudit.addRegionToAnEntry",
                "title": "weAudit: Add Region to a Finding"
            },
            {
                "command": "weAudit.addRegionToAnEntryWithLabel",
                "title": "weAudit: Add Region to a Finding with Label"
            },
            {
                "command": "weAudit.showFindingsSearchBar",
                "title": "weAudit: Search and Filter Findings"
            },
            {
                "command": "weAudit.exportFindingsInMarkdown",
                "title": "weAudit: Export Findings as Markdown",
                "icon": "$(markdown)"
            },
            {
                "command": "weAudit.navigateToNextPartiallyAuditedRegion",
                "title": "weAudit: Navigate to Next Partially Audited Region"
            },
            {
                "command": "weAudit.toggleFindingsHighlighting",
                "title": "weAudit: Toggle Findings Highlighting"
            },
            {
                "command": "weAudit.editFindingBoundary",
                "title": "weAudit: Edit Finding Boundary"
            },
            {
                "command": "weAudit.stopEditingBoundary",
                "title": "weAudit: Stop Editing Finding Boundary"
            },
            {
                "command": "weAudit.boundaryExpandUp",
                "title": "weAudit: Expand Finding Boundary Up"
            },
            {
                "command": "weAudit.boundaryShrinkTop",
                "title": "weAudit: Shrink Finding Boundary from Top"
            },
            {
                "command": "weAudit.boundaryExpandDown",
                "title": "weAudit: Expand Finding Boundary Down"
            },
            {
                "command": "weAudit.boundaryShrinkBottom",
                "title": "weAudit: Shrink Finding Boundary from Bottom"
            },
            {
                "command": "weAudit.boundaryMoveUp",
                "title": "weAudit: Move Finding Up"
            },
            {
                "command": "weAudit.boundaryMoveDown",
                "title": "weAudit: Move Finding Down"
            },
            {
                "command": "weAudit.initializeProjectConfig",
                "title": "weAudit: Initialize Project Config"
            },
            {
                "command": "weAudit.validateProjectConfig",
                "title": "weAudit: Validate Project Config"
            }
        ],
        "keybindings": [
            {
                "command": "weAudit.toggleAudited",
                "key": "ctrl+alt+7",
                "mac": "cmd+7"
            },
            {
                "command": "weAudit.addPartiallyAudited",
                "key": "ctrl+shift+7",
                "mac": "cmd+shift+7"
            },
            {
                "command": "weAudit.addFinding",
                "key": "ctrl+alt+3",
                "mac": "cmd+3"
            },
            {
                "command": "weAudit.addNote",
                "key": "ctrl+alt+4",
                "mac": "cmd+4"
            },
            {
                "command": "weAudit.deleteLocationUnderCursor",
                "key": "ctrl+alt+5",
                "mac": "cmd+5"
            },
            {
                "command": "weAudit.copySelectedCodePermalink",
                "key": "ctrl+alt+8",
                "mac": "cmd+8"
            },
            {
                "command": "weAudit.copySelectedCodeClientPermalink",
                "key": "ctrl+alt+9",
                "mac": "cmd+9"
            },
            {
                "command": "weAudit.navigateToNextPartiallyAuditedRegion",
                "key": "ctrl+alt+0",
                "mac": "cmd+0"
            },
            {
                "command": "weAudit.boundaryExpandUp",
                "key": "ctrl+shift+numpad7",
                "mac": "cmd+shift+numpad7",
                "when": "editorTextFocus"
            },
            {
                "command": "weAudit.boundaryMoveUp",
                "key": "ctrl+shift+numpad8",
                "mac": "cmd+shift+numpad8",
                "when": "editorTextFocus"
            },
            {
                "command": "weAudit.boundaryShrinkTop",
                "key": "ctrl+shift+numpad9",
                "mac": "cmd+shift+numpad9",
                "when": "editorTextFocus"
            },
            {
                "command": "weAudit.boundaryExpandDown",
                "key": "ctrl+shift+numpad1",
                "mac": "cmd+shift+numpad1",
                "when": "editorTextFocus"
            },
            {
                "command": "weAudit.boundaryMoveDown",
                "key": "ctrl+shift+numpad2",
                "mac": "cmd+shift+numpad2",
                "when": "editorTextFocus"
            },
            {
                "command": "weAudit.boundaryShrinkBottom",
                "key": "ctrl+shift+numpad3",
                "mac": "cmd+shift+numpad3",
                "when": "editorTextFocus"
            },
            {
                "command": "weAudit.stopEditingBoundary",
                "key": "ctrl+shift+numpad5",
                "mac": "cmd+shift+numpad5",
                "when": "weAudit.boundaryEditing && editorTextFocus"
            },
            {
                "command": "weAudit.editFindingBoundary",
                "key": "ctrl+shift+numpad5",
                "mac": "cmd+shift+numpad5",
                "when": "!weAudit.boundaryEditing && editorTextFocus"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "weAudit.editLocationEntry",
                    "when": "false"
                },
                {
                    "command": "weAudit.resolveFinding",
                    "when": "false"
                },
                {
                    "command": "weAudit.copyFindingAsMarkdown",
                    "when": "false"
                },
                {
                    "command": "weAudit.copyEntryPermalink",
                    "when": "false"
                },
                {
                    "command": "weAudit.findAndLoadConfigurationFiles",
                    "when": "false"
                },
                {
                    "command": "weAudit.restoreFinding",
                    "when": "false"
                },
                {
                    "command": "weAudit.deleteFinding",
                    "when": "false"
                },
                {
                    "command": "weAudit.deleteLocation",
                    "when": "false"
                },
                {
                    "command": "weAudit.deleteResolvedFinding",
                    "when": "false"
                },
                {
                    "command": "weAudit.deleteAllResolvedFinding",
                    "when": "false"
                },
                {
                    "command": "weAudit.boundaryExpandUp",
                    "when": "false"
                },
                {
                    "command": "weAudit.boundaryShrinkTop",
                    "when": "false"
                },
                {
                    "command": "weAudit.boundaryExpandDown",
                    "when": "false"
                },
                {
                    "command": "weAudit.boundaryShrinkBottom",
                    "when": "false"
                },
                {
                    "command": "weAudit.boundaryMoveUp",
                    "when": "false"
                },
                {
                    "command": "weAudit.boundaryMoveDown",
                    "when": "false"
                }
            ],
            "view/title": [
                {
                    "command": "weAudit.findAndLoadConfigurationFiles",
                    "when": "view == savedFindings",
                    "group": "navigation"
                },
                {
                    "command": "weAudit.restoreAllResolvedFindings",
                    "when": "view == resolvedFindings",
                    "group": "navigation@1"
                },
                {
                    "command": "weAudit.deleteAllResolvedFinding",
                    "when": "view == resolvedFindings",
                    "group": "navigation@2"
                },
                {
                    "command": "weAudit.showMarkedFilesDayLog",
                    "when": "view == codeMarker",
                    "group": "navigation@0"
                },
                {
                    "command": "weAudit.exportFindingsInMarkdown",
                    "when": "view == codeMarker",
                    "group": "navigation@1"
                },
                {
                    "command": "weAudit.toggleTreeViewMode",
                    "when": "view == codeMarker",
                    "group": "navigation@2"
                },
                {
                    "command": "weAudit.copyFindingAsMarkdownFromDetails",
                    "when": "view == findingDetails && weAudit.findingDetailsHasEntry",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "weAudit.copyEntryPermalink",
                    "when": "view == codeMarker && viewItem == additionalLocation",
                    "group": "inline@2"
                },
                {
                    "command": "weAudit.copyEntryPermalinks",
                    "when": "view == codeMarker && viewItem != pathOrganizer && viewItem != additionalLocation",
                    "group": "inline@2"
                },
                {
                    "command": "weAudit.copyFindingAsMarkdown",
                    "when": "view == codeMarker && viewItem != pathOrganizer && viewItem != additionalLocation",
                    "group": "inline@1"
                },
                {
                    "command": "weAudit.resolveFinding",
                    "when": "view == codeMarker && viewItem != pathOrganizer && viewItem != additionalLocation",
                    "group": "inline@3"
                },
                {
                    "command": "weAudit.deleteFinding",
                    "when": "view == codeMarker && viewItem != pathOrganizer && viewItem != additionalLocation",
                    "group": "inline@4"
                },
                {
                    "command": "weAudit.deleteLocation",
                    "when": "view == codeMarker && viewItem == additionalLocation",
                    "group": "inline@3"
                },
                {
                    "command": "weAudit.editLocationEntry",
                    "when": "view == codeMarker && viewItem == additionalLocation",
                    "group": "inline@1"
                },
                {
                    "command": "weAudit.restoreFinding",
                    "when": "view == resolvedFindings",
                    "group": "inline@1"
                },
                {
                    "command": "weAudit.deleteResolvedFinding",
                    "when": "view == resolvedFindings",
                    "group": "inline@2"
                }
            ],
            "editor/context": [
                {
                    "command": "weAudit.toggleAudited",
                    "group": "1_modification@0"
                },
                {
                    "command": "weAudit.copySelectedCodePermalink",
                    "group": "9_cutcopypaste@0"
                },
                {
                    "command": "weAudit.copySelectedCodeClientPermalink",
                    "group": "9_cutcopypaste@0"
                }
            ]
        },
        "configuration": [
            {
                "title": "General Settings",
                "order": 1,
                "properties": {
                    "weAudit.general.treeViewMode": {
                        "type": "string",
                        "default": "list",
                        "enum": [
                            "list",
                            "byFile"
                        ],
                        "enumDescriptions": [
                            "Group findings in a list",
                            "Group findings by filename"
                        ],
                        "description": "The List of Findings display mode."
                    },
                    "weAudit.general.username": {
                        "type": "string",
                        "default": "",
                        "description": "The username to use as the finding's author. (Defaults to the system's username if left empty.)"
                    },
                    "weAudit.general.permalinkSeparator": {
                        "type": "string",
                        "default": "\\n",
                        "description": "The separator to use in permalinks. (Note that \\n is interpreted as a newline)"
                    },
                    "weAudit.general.sortEntriesAlphabetically": {
                        "type": "boolean",
                        "default": false,
                        "description": "Sort findings and notes alphabetically by name in the tree view."
                    },
                    "weAudit.findingSchema.labelTemplate": {
                        "type": "string",
                        "default": "${title}",
                        "description": "Template used to render finding labels in the tree view. Supports placeholders like ${title}, ${severity}, and custom finding detail fields. Notes are not affected."
                    },
                    "weAudit.findingSchema.fields": {
                        "type": "array",
                        "description": "Additional finding detail fields rendered after title and description. Define severity here if the workspace uses a severity taxonomy.",
                        "default": [
                            {
                                "key": "severity",
                                "label": "Severity",
                                "type": "select",
                                "options": [
                                    "",
                                    "Code Quality",
                                    "Informational",
                                    "Undetermined",
                                    "Low",
                                    "Medium",
                                    "High"
                                ]
                            },
                            {
                                "key": "difficulty",
                                "label": "Difficulty",
                                "type": "select",
                                "options": [
                                    "",
                                    "Undetermined",
                                    "Not Applicable",
                                    "Low",
                                    "Medium",
                                    "High"
                                ],
                                "visibleWhen": {
                                    "field": "severity",
                                    "notEquals": "Code Quality"
                                }
                            },
                            {
                                "key": "type",
                                "label": "Type",
                                "type": "select",
                                "options": [
                                    "",
                                    "Access Controls",
                                    "Auditing and Logging",
                                    "Authentication",
                                    "Configuration",
                                    "Cryptography",
                                    "Data Exposure",
                                    "Data Validation",
                                    "Denial of Service",
                                    "Error Reporting",
                                    "Patching",
                                    "Session Management",
                                    "Testing",
                                    "Timing",
                                    "Undefined Behavior"
                                ],
                                "visibleWhen": {
                                    "field": "severity",
                                    "notEquals": "Code Quality"
                                }
                            },
                            {
                                "key": "exploit",
                                "label": "Exploit Scenario",
                                "type": "textarea",
                                "placeholder": "The exploit scenario",
                                "rows": 5,
                                "visibleWhen": {
                                    "field": "severity",
                                    "notEquals": "Code Quality"
                                }
                            },
                            {
                                "key": "recommendation",
                                "label": "Recommendations",
                                "type": "textarea",
                                "rows": 5,
                                "visibleWhen": {
                                    "field": "severity",
                                    "notEquals": "Code Quality"
                                }
                            }
                        ],
                        "items": {
                            "type": "object",
                            "required": [
                                "key",
                                "label",
                                "type"
                            ],
                            "properties": {
                                "key": {
                                    "type": "string",
                                    "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
                                },
                                "label": {
                                    "type": "string"
                                },
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "text",
                                        "textarea",
                                        "select",
                                        "checkbox",
                                        "number"
                                    ]
                                },
                                "required": {
                                    "type": "boolean"
                                },
                                "options": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "placeholder": {
                                    "type": "string"
                                },
                                "rows": {
                                    "type": "number"
                                },
                                "visibleWhen": {
                                    "type": "object",
                                    "properties": {
                                        "field": {
                                            "type": "string"
                                        },
                                        "equals": {},
                                        "notEquals": {}
                                    }
                                }
                            }
                        }
                    }
                }
            },
            {
                "title": "Highlight colors",
                "order": 2,
                "properties": {
                    "weAudit.auditedColor": {
                        "type": "string",
                        "default": "#00422355",
                        "description": "Background color for files marked as reviewed (write as #RGB, #RGBA, #RRGGBB or #RRGGBBAA)."
                    },
                    "weAudit.ownFindingColor": {
                        "type": "string",
                        "default": "#ee335555",
                        "description": "Background color for your own findings (write as #RGB, #RGBA, #RRGGBB or #RRGGBBAA)."
                    },
                    "weAudit.otherFindingColor": {
                        "type": "string",
                        "default": "#ee335555",
                        "description": "Background color for other user's findings (write as #RGB, #RGBA, #RRGGBB or #RRGGBBAA)."
                    },
                    "weAudit.ownNoteColor": {
                        "type": "string",
                        "default": "#145ceb55",
                        "description": "Background color for your own notes (write as #RGB, #RGBA, #RRGGBB or #RRGGBBAA)."
                    },
                    "weAudit.otherNoteColor": {
                        "type": "string",
                        "default": "#145ceb55",
                        "description": "Background color for other user's notes (write as #RGB, #RGBA, #RRGGBB or #RRGGBBAA)."
                    }
                }
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "node ./esbuild.js",
        "package": "node ./esbuild.js --production",
        "watch": "node ./esbuild.js --watch",
        "lint": "eslint --ext ts --color -c .eslintrc.cjs src",
        "test": "npm run test:unit && npm run test:ext",
        "test:all": "npm run test:unit && npm run test:ext && npm run test:ui",
        "test:unit": "mocha -r ts-node/register/transpile-only \"test/unit/**/*.test.ts\" \"test/webview/**/*.test.ts\"",
        "pretest:ext": "npm run compile && tsc -p test/extension/tsconfig.json",
        "test:ext": "vscode-test --config .vscode-test.mjs",
        "pretest:ui": "npm run compile && tsc -p test/ui/tsconfig.json",
        "test:ui": "extest setup-and-run './out/test/ui/**/*.test.js' --code_version max --storage .test-extensions --extensions_dir .test-extensions/extensions --mocha_config test/ui/.mocharc.json -- --disable-extensions",
        "test:ui-setup": "extest setup-tests --code_version max --storage .test-extensions --extensions_dir .test-extensions/extensions",
        "coverage": "nyc npm run test:unit",
        "lint:fix": "eslint --ext ts -c .eslintrc.cjs src --fix",
        "format": "biome format --write .",
        "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.11",
        "@microsoft/eslint-formatter-sarif": "^3.1.0",
        "@stylistic/eslint-plugin": "^5.7.0",
        "@types/asciichart": "^1.5.6",
        "@types/chai": "^4.3.20",
        "@types/glob": "^9.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "25.x",
        "@types/sinon": "^21.0.0",
        "@types/vscode": "^1.108.1",
        "@types/vscode-webview": "^1.57.1",
        "@typescript-eslint/eslint-plugin": "^8.53.0",
        "@typescript-eslint/parser": "^8.50.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "chai": "^6.2.2",
        "esbuild": "^0.27.2",
        "eslint": "^9.39.2",
        "glob": "^13.0.0",
        "mocha": "^11.3.0",
        "nyc": "^17.1.0",
        "sinon": "^21.0.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "vscode-extension-tester": "^8.21.0"
    },
    "dependencies": {
        "@vscode/webview-ui-toolkit": "^1.4.0",
        "asciichart": "^1.5.25"
    }
}
